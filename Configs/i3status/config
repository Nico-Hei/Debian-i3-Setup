# NOT IN USE: i3blocks

general {
        colors = true
        interval = 5
}

order += "battery all"
order += "memory"
order += "tztime local"

battery all {
        format = "%status %percentage %remaining"
}

memory {
        format = "RAM (used): %used"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

tztime local {
        format = "%d.%m.%Y | %H:%M"
}